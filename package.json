{
  "name": "boli-p2p-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "seed:banks": "tsx src/scripts/seed-banks.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "bybit-api": "^4.6.1",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.0",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
